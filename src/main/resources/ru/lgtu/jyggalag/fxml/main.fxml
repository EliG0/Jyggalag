<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="900.0" minWidth="1300.0" styleClass="root,jy-root" stylesheets="@../styles/jyggalag.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.lgtu.jyggalag.ui.controllers.MainController">


    <left>
        <VBox fx:id="sideBar" prefWidth="240.0" spacing="4" styleClass="jy-sidebar">
            <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>


            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="jy-sidebar-logo">
                <padding><Insets bottom="16" left="4" right="4" top="8" /></padding>
                <Label styleClass="jy-sidebar-logo-icon" text="✦" />
                <Label text="Jyggalag">
               <styleClass>
                  <String fx:value="jy-title" />
                  <String fx:value="jy-main-logo" />
               </styleClass></Label>
            </HBox>


            <Label styleClass="jy-label" text="МЕНЮ">
                <padding><Insets bottom="4" left="6" right="4" top="4" /></padding>
            </Label>


            <Button fx:id="todayButton" maxWidth="1.7976931348623157E308" onAction="#handleNavToday" styleClass="jy-nav-item,jy-nav-item-active">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label fx:id="todayIcon" styleClass="jy-nav-icon" text="◈" />
                        <Label fx:id="todayLabel" styleClass="jy-nav-label" text="Сегодня" />
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="tasksButton" maxWidth="1.7976931348623157E308" onAction="#handleNavTasks" styleClass="jy-nav-item">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="jy-nav-icon" text="☑" />
                        <Label styleClass="jy-nav-label" text="Мои задачи" />
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="notesButton" maxWidth="1.7976931348623157E308" onAction="#handleNavNotes" styleClass="jy-nav-item">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="jy-nav-icon" text="◇" />
                        <Label styleClass="jy-nav-label" text="Заметки" />
                    </HBox>
                </graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS" />

            <Label styleClass="jy-label" text="ПРОЧЕЕ">
                <padding><Insets bottom="4" left="6" right="4" top="4" /></padding>
            </Label>
         <Button fx:id="reportButton" maxWidth="1.7976931348623157E308" onAction="#handleReport" styleClass="jy-nav-item">
            <graphic>
               <HBox alignment="CENTER_LEFT" spacing="12">
                  <children>
                     <Label styleClass="jy-nav-icon" text="📃" />
                     <Label styleClass="jy-nav-label" text="Отчёт" />
                  </children>
               </HBox>
            </graphic>
         </Button>

            <Button fx:id="logoutButton" maxWidth="1.7976931348623157E308" onAction="#handleLogout" styleClass="jy-nav-item">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="jy-nav-icon" text="⚙" />
                        <Label styleClass="jy-nav-label" text="Выйти" />
                    </HBox>
                </graphic>
            </Button>

        </VBox>
    </left>

    <center>
        <BorderPane fx:id="mainWallpapers" styleClass="main,background" BorderPane.alignment="CENTER">

            <top>
                <HBox fx:id="mainHeader" alignment="CENTER_RIGHT" onMouseDragged="#handleMouseDragged" onMousePressed="#handleMousePressed" spacing="0">
                    <styleClass>
                        <String fx:value="transparent" />
                        <String fx:value="mainHeader" />
                    </styleClass>

                    <Button fx:id="minimizeButton" minHeight="30.0" minWidth="50.0" mnemonicParsing="false" onAction="#handleMinimize" styleClass="windowButton,windowButton-minimize">
                        <graphic>
                            <Label styleClass="windowButton-icon" text="—" />
                        </graphic>
                    </Button>

                    <Button fx:id="maximizeButton" minHeight="30.0" minWidth="50.0" mnemonicParsing="false" onAction="#handleMaximize" styleClass="windowButton,windowButton-maximize">
                        <graphic>
                            <Label styleClass="windowButton-icon" text="⬜" />
                        </graphic>
                    </Button>
                    <Button fx:id="closeButton" minHeight="30.0" minWidth="50.0" mnemonicParsing="false" onAction="#handleClose" styleClass="windowButton,windowButton-close">
                        <graphic>
                            <Label styleClass="windowButton-icon" text="✕" />
                        </graphic>
                    </Button>
               <padding>
                  <Insets right="8.0" top="8.0" />
               </padding>

                </HBox>
            </top>
            <center>
                <StackPane fx:id="contentArea" alignment="TOP_LEFT" BorderPane.alignment="CENTER" />
            </center>

        </BorderPane>
    </center>

</BorderPane>
